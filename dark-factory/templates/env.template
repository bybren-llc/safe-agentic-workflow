# Dark Factory Environment Configuration
# Copy to ~/.dark-factory/env and customize for your project
#
# See: dark-factory/docs/DARK-FACTORY-GUIDE.md

# Project settings (REQUIRED -- replace placeholders)
FACTORY_PROJECT_DIR="{{PROJECT_PATH}}"
FACTORY_MAIN_BRANCH="{{MAIN_BRANCH}}"
FACTORY_TICKET_PREFIX="{{TICKET_PREFIX}}"

# Remote access (for teams connecting via SSH)
FACTORY_SSH_KEY="{{SSH_KEY_PATH}}"
FACTORY_REMOTE_HOST="{{REMOTE_HOST}}"
FACTORY_REMOTE_USER="{{REMOTE_USER}}"

# Local paths (defaults are fine for most setups)
FACTORY_LOG_DIR="$HOME/.dark-factory/logs"
FACTORY_WORKTREE_DIR="$HOME/.dark-factory/worktrees"

# Feature flags
FACTORY_USE_WORKTREES=true
FACTORY_AUTO_PERMISSIONS=true

# Claude Code settings
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# Merge policy (do not change -- enforced by factory-setup.sh)
FACTORY_MERGE_METHOD="squash"
FACTORY_REQUIRE_QUEUE=true
