{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/main/schemas/settings.schema.json",
  "context": {
    "includePatterns": [
      "**/*.md",
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "**/*.yaml",
      "**/*.yml",
      "**/*.toml",
      "**/*.sql",
      "**/*.prisma"
    ],
    "excludePatterns": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      ".next/**",
      "coverage/**",
      "*.log",
      ".env*"
    ],
    "fileFiltering": {
      "respectGitIgnore": true,
      "respectGeminiIgnore": true
    }
  },
  "tools": {
    "sandbox": true,
    "useRipgrep": true
  },
  "model": {
    "name": "gemini-2.0-flash-exp"
  },
  "ui": {
    "showLineNumbers": true,
    "useFullWidth": true
  },
  "mcpServers": {}
}
