{
  "$schema": "https://geminicli.com/schemas/settings.json",
  "context": {
    "includePatterns": [
      "**/*.md",
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "**/*.yaml",
      "**/*.yml",
      "**/*.toml",
      "**/*.sql",
      "**/*.prisma"
    ],
    "excludePatterns": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      ".next/**",
      "coverage/**",
      "*.log",
      ".env*"
    ],
    "fileFiltering": {
      "respectGitIgnore": true,
      "respectGeminiIgnore": true
    }
  },
  "tools": {
    "sandbox": {
      "enabled": true
    },
    "shell": {
      "enableInteractiveShell": true
    },
    "useRipgrep": true,
    "enableToolOutputTruncation": true
  },
  "model": {
    "default": "gemini-2.0-flash-exp"
  },
  "ui": {
    "showLineNumbers": true,
    "useFullWidth": true,
    "incrementalRendering": true
  },
  "hooks": {
    "enabled": false,
    "notifications": true
  },
  "mcpServers": {
  }
}
